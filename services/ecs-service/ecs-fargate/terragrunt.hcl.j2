# -----------------------------------------------------------------------------
# ECS Fargate Service: {{ service_name }} — Auto-generated by Keystone Platform
# Jira: {{ jira_ticket_key }}
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//ecs-fargate?ref={{ iac_template_ref }}"
}

{% if existing_vpc_id %}
dependency "vpc" {
  config_path = "../../vpc/{{ service_name }}"
  skip_outputs = true

  mock_outputs = {
    vpc_id              = "vpc-mock"
    private_subnet_ids  = ["subnet-1", "subnet-2"]
    public_subnet_ids   = ["subnet-1", "subnet-2"]
  }
}
{% endif %}

inputs = {
  service_name    = "{{ service_name }}"
  container_image = "{{ container_image }}"
  container_port  = {{ container_port | default(8080) }}
  cpu             = {{ cpu | default(512) }}
  memory          = {{ memory | default(1024) }}
  desired_count   = {{ desired_count | default(2) }}

  enable_autoscaling = {{ enable_autoscaling | default(true) | lower }}
  autoscaling_max    = {{ autoscaling_max | default(10) }}

  health_check_path = "{{ health_check_path | default('/health') }}"

  {% if existing_vpc_id %}
  vpc_id             = "{{ existing_vpc_id }}"
  {% endif %}

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "keystone-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
