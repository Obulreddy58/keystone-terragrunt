# -----------------------------------------------------------------------------
# EKS Upgrade — Root Terragrunt Config
# Auto-generated by Keystone Platform (portal-initiated, not Jira)
# Upgrade: {{ current_version }} → {{ target_version }}
# Cluster: {{ cluster_name }}
# Team: {{ team_name }}
# Environment: {{ environment }}
# Strategy: {{ upgrade_strategy | default('rolling') }}
# -----------------------------------------------------------------------------
#
# UPGRADE ORDER (each stage is a separate terragrunt apply):
#   1. control-plane/  — EKS API server + etcd version bump
#   2. addons/         — VPC CNI, CoreDNS, kube-proxy, karpenter
#   3. node-groups/    — Rolling update of worker nodes
#
# PRE-REQUISITES:
#   ✓ Release notes reviewed for API deprecations
#   ✓ Lower environment validated (2-week grace period)
#   ✓ Cluster health checks passed
#   ✓ PodDisruptionBudgets configured for critical workloads
#   ✓ ≥ 5 available IPs in node subnets
#   ✓ No version downgrade (N → N+1 only)
#   ✓ kubelet matches control plane version
#   ✓ cluster-autoscaler / karpenter matches control plane version
#
# ROLLBACK PLAN:
#   Control Plane: aws eks update-cluster-version → previous version
#   Node Groups:   terraform state revert → previous launch template
#   Workloads:     kubectl rollout undo → previous deployment
# -----------------------------------------------------------------------------

locals {
  aws_region     = "{{ aws_region | default('us-east-1') }}"
  environment    = "{{ environment }}"
  cluster_name   = "{{ cluster_name }}"
  target_version = "{{ target_version }}"
}

generate "provider" {
  path      = "provider.tf"
  if_exists = "overwrite_terragrunt"
  contents  = <<-EOF
    provider "aws" {
      region = "${local.aws_region}"

      default_tags {
        tags = {
          Project        = "${local.cluster_name}"
          Environment    = "${local.environment}"
          ManagedBy      = "terragrunt"
          Team           = "{{ team_name }}"
          CostCenter     = "{{ cost_center }}"
          UpgradeVersion = "${local.target_version}"
          UpgradeTicket  = "{{ jira_ticket_key }}"
        }
      }
    }
  EOF
}

remote_state {
  backend = "s3"
  generate = {
    path      = "backend.tf"
    if_exists = "overwrite_terragrunt"
  }
  config = {
    bucket       = "${local.cluster_name}-${local.environment}-terraform-state"
    key          = "${path_relative_to_include()}/terraform.tfstate"
    region       = local.aws_region
    encrypt      = true
    use_lockfile = true
  }
}
