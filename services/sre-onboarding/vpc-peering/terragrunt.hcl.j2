# -----------------------------------------------------------------------------
# VPC Peering: {{ team_name }} VPC → Central Monitoring VPC
# Auto-generated by Self-Service API
# Jira: {{ jira_ticket_key }}
#
# Peers the team's EKS VPC with the platform team's central monitoring VPC
# so that Prometheus/OTel can remote-write metrics to AMP/Mimir.
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//vpc-peering?ref={{ iac_template_ref }}"
}

inputs = {
  # Requester side (team's VPC)
  requester_vpc_id   = "{{ team_vpc_id }}"
  {% if team_vpc_cidr %}
  requester_vpc_cidr = "{{ team_vpc_cidr }}"
  {% endif %}

  # Accepter side (central monitoring VPC)
  accepter_vpc_id       = "{{ central_monitoring_vpc_id }}"
  accepter_vpc_cidr     = "{{ central_monitoring_vpc_cidr }}"
  {% if central_monitoring_account_id %}
  accepter_account_id   = "{{ central_monitoring_account_id }}"
  {% endif %}

  # Route table updates — allow traffic from team VPC to monitoring VPC
  auto_accept               = {{ (central_monitoring_account_id == account_id) | lower }}
  allow_remote_vpc_dns_resolution = true

  tags = {
    Name        = "{{ team_name }}-to-central-monitoring"
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    Purpose     = "observability"
    JiraTicket  = "{{ jira_ticket_key }}"
    ManagedBy   = "terragrunt"
  }
}
