# -----------------------------------------------------------------------------
# VPC: {{ vpc_name }} — Auto-generated by Keystone Platform
# Jira: {{ jira_ticket_key }}
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//vpc?ref={{ iac_template_ref }}"
}

inputs = {
  name        = "{{ vpc_name }}"
  environment = "{{ environment }}"
  vpc_cidr    = "{{ vpc_cidr }}"

  # 3 AZs
  azs = ["{{ aws_region }}a", "{{ aws_region }}b", "{{ aws_region }}c"]

  private_subnet_cidrs  = [cidrsubnet("{{ vpc_cidr }}", 4, 0), cidrsubnet("{{ vpc_cidr }}", 4, 1), cidrsubnet("{{ vpc_cidr }}", 4, 2)]
  public_subnet_cidrs   = [cidrsubnet("{{ vpc_cidr }}", 4, 3), cidrsubnet("{{ vpc_cidr }}", 4, 4), cidrsubnet("{{ vpc_cidr }}", 4, 5)]
  database_subnet_cidrs = [cidrsubnet("{{ vpc_cidr }}", 4, 6), cidrsubnet("{{ vpc_cidr }}", 4, 7), cidrsubnet("{{ vpc_cidr }}", 4, 8)]

  enable_nat_gateway = {{ enable_nat_gateway | default(true) | lower }}
  {% if environment == "prod" %}
  single_nat_gateway = false
  {% else %}
  single_nat_gateway = {{ single_nat_gateway | default(true) | lower }}
  {% endif %}

  enable_flow_logs = true

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "keystone-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
