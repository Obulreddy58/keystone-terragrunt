# -----------------------------------------------------------------------------
# DynamoDB Table: {{ table_name }} — Auto-generated by Keystone Platform
# Jira: {{ jira_ticket_key }}
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//dynamodb?ref={{ iac_template_ref }}"
}

inputs = {
  table_name         = "{{ table_name }}"
  billing_mode       = "{{ billing_mode | default('PAY_PER_REQUEST') }}"
  partition_key      = "{{ partition_key }}"
  partition_key_type = "{{ partition_key_type | default('S') }}"

  {% if sort_key %}
  sort_key      = "{{ sort_key }}"
  sort_key_type = "{{ sort_key_type | default('S') }}"
  {% endif %}

  enable_streams              = {{ enable_streams | default(false) | lower }}
  enable_point_in_time_recovery = {{ enable_point_in_time_recovery | default(true) | lower }}

  # Encryption
  sse_enabled = true

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "keystone-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
