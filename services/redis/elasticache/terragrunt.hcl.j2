# -----------------------------------------------------------------------------
# ElastiCache Redis: {{ cluster_name }} — Auto-generated by Keystone Platform
# Jira: {{ jira_ticket_key }}
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//elasticache?ref={{ iac_template_ref }}"
}

inputs = {
  cluster_name   = "{{ cluster_name }}"
  node_type      = "{{ node_type | default('cache.t3.medium') }}"
  num_nodes      = {{ num_nodes | default(2) }}
  engine_version = "{{ engine_version | default('7.0') }}"

  multi_az = {{ multi_az | default(false) | lower }}

  {% if existing_vpc_id %}
  vpc_id = "{{ existing_vpc_id }}"
  {% endif %}

  # Encryption
  at_rest_encryption_enabled = true
  transit_encryption_enabled = true

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "keystone-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
