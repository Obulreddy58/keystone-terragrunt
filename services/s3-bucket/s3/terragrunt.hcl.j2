# -----------------------------------------------------------------------------
# S3 Bucket: {{ bucket_name }} — Auto-generated by Keystone Platform
# Jira: {{ jira_ticket_key }}
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//s3?ref={{ iac_template_ref }}"
}

inputs = {
  bucket_name = "{{ bucket_name }}"

  versioning = {{ versioning | default(true) | lower }}

  enable_lifecycle         = {{ enable_lifecycle | default(false) | lower }}
  lifecycle_ia_days        = {{ lifecycle_ia_days | default(90) }}
  lifecycle_glacier_days   = {{ lifecycle_glacier_days | default(365) }}

  enable_cloudfront = {{ enable_cloudfront | default(false) | lower }}

  # Security defaults
  block_public_access = true
  sse_algorithm       = "aws:kms"
  bucket_key_enabled  = true

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "keystone-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
