# -----------------------------------------------------------------------------
# Route53 DNS: {{ domain_name }} — Auto-generated by Keystone Platform
# Jira: {{ jira_ticket_key }}
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//route53?ref={{ iac_template_ref }}"
}

inputs = {
  domain_name  = "{{ domain_name }}"
  private_zone = {{ private_zone | default(false) | lower }}

  {% if private_zone and existing_vpc_id %}
  vpc_id = "{{ existing_vpc_id }}"
  {% endif %}

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "keystone-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
