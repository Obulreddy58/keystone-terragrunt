# ─────────────────────────────────────────────────────────────────────────────
# Account Baseline — {{ team_name }}-{{ environment }}
# Bootstraps OIDC, state bucket, security defaults in the new account
# Auto-generated by Self-Service Platform
# Jira: {{ jira_ticket_key }}
# ─────────────────────────────────────────────────────────────────────────────

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//account-baseline?ref={{ iac_template_ref }}"
}

include "root" {
  path = find_in_parent_folders("terragrunt.hcl")
}

dependency "account" {
  config_path = "../account-factory"

  mock_outputs = {
    account_id = "000000000000"
  }
}

# Provider configured to assume role into the NEW account
generate "provider" {
  path      = "provider_override.tf"
  if_exists = "overwrite_terragrunt"
  contents  = <<-EOF
    provider "aws" {
      region = "{{ aws_region }}"
      assume_role {
        role_arn = "arn:aws:iam::$${dependency.account.outputs.account_id}:role/OrganizationAccountAccessRole"
      }
    }
  EOF
}

inputs = {
  account_id = dependency.account.outputs.account_id
  team_name  = "{{ team_name }}"
  aws_region = "{{ aws_region }}"

  # GitHub OIDC — allow the team's infra repo to deploy
  github_oidc_subjects = [
    "repo:{{ github_group }}/{{ github_repo }}:*",
  ]

  github_actions_role_name  = "github-actions-terraform"
  github_actions_policy_arn = "arn:aws:iam::aws:policy/AdministratorAccess"

  # Security
  enable_cloudtrail      = {{ enable_cloudtrail | default(true) | lower }}
  central_logging_bucket = ""  # Set this to your log-archive bucket name

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "self-service-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
