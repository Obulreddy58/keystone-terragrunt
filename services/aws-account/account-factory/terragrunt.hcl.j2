# ─────────────────────────────────────────────────────────────────────────────
# Account Factory — {{ team_name }}-{{ environment }}
# Auto-generated by Self-Service Platform
# Jira: {{ jira_ticket_key }}
# ─────────────────────────────────────────────────────────────────────────────

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//account-factory?ref={{ iac_template_ref }}"
}

include "root" {
  path = find_in_parent_folders("terragrunt.hcl")
}

inputs = {
  account_name = "{{ team_name }}-{{ environment }}"
  account_email = "{{ account_email_prefix | default('aws+' ~ team_name ~ '-' ~ environment ~ '@company.com', true) }}"
  ou_id        = "{{ ou_path }}"
  team_name    = "{{ team_name }}"
  environment  = "{{ environment }}"
  cost_center  = "{{ cost_center }}"

  # SSO / Identity Center (set to true once configured)
  enable_sso_assignment = false

  # Security
  enable_guardduty = {{ enable_guardduty | default(true) | lower }}

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "self-service-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
