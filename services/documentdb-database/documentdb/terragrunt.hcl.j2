# -----------------------------------------------------------------------------
# DocumentDB Cluster: {{ cluster_name }} — Auto-generated
# Jira: {{ jira_ticket_key }}
# Engine: docdb {{ engine_version }}
# Instances: {{ num_instances }}x {{ instance_class }}
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//documentdb?ref={{ iac_template_ref }}"
}

{% if existing_vpc_id %}
# Using existing shared VPC
inputs = {
  name = "{{ cluster_name }}"

  engine_version = "{{ engine_version }}"
  instance_class = "{{ instance_class }}"
  num_instances  = {{ num_instances }}

  master_username = "{{ master_username }}"

  deletion_protection     = {{ deletion_protection | lower }}
  backup_retention_period = {{ backup_retention_days }}
  backup_window           = "03:00-04:00"
  maintenance_window      = "sun:05:00-sun:06:00"

  vpc_id = "{{ existing_vpc_id }}"

  {% if environment == "prod" %}
  skip_final_snapshot = false
  {% else %}
  skip_final_snapshot = true
  {% endif %}

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    ManagedBy   = "keystone"
    Service     = "documentdb"
    CostCenter  = "{{ cost_center }}"
    CreatedBy   = "{{ requester_email }}"
  }
}
{% else %}
# Create a new VPC via dependency
dependency "vpc" {
  config_path = "../vpc"

  mock_outputs = {
    vpc_id              = "vpc-00000000000000000"
    database_subnet_ids = ["subnet-aaa", "subnet-bbb", "subnet-ccc"]
  }
  mock_outputs_allowed_terraform_commands = ["init", "validate", "plan"]
}

inputs = {
  name = "{{ cluster_name }}"

  engine_version = "{{ engine_version }}"
  instance_class = "{{ instance_class }}"
  num_instances  = {{ num_instances }}

  master_username = "{{ master_username }}"

  deletion_protection     = {{ deletion_protection | lower }}
  backup_retention_period = {{ backup_retention_days }}
  backup_window           = "03:00-04:00"
  maintenance_window      = "sun:05:00-sun:06:00"

  vpc_id              = dependency.vpc.outputs.vpc_id
  database_subnet_ids = dependency.vpc.outputs.database_subnet_ids

  {% if environment == "prod" %}
  skip_final_snapshot = false
  {% else %}
  skip_final_snapshot = true
  {% endif %}

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    ManagedBy   = "keystone"
    Service     = "documentdb"
    CostCenter  = "{{ cost_center }}"
    CreatedBy   = "{{ requester_email }}"
  }
}
{% endif %}
