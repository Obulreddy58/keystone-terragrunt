# -----------------------------------------------------------------------------
# Lambda Function: {{ function_name }} — Auto-generated by Keystone Platform
# Jira: {{ jira_ticket_key }}
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//lambda?ref={{ iac_template_ref }}"
}

inputs = {
  function_name = "{{ function_name }}"
  runtime       = "{{ runtime | default('python3.12') }}"
  memory_size   = {{ memory_size | default(256) }}
  timeout       = {{ timeout | default(30) }}

  enable_api_gateway = {{ enable_api_gateway | default(false) | lower }}

  {% if enable_vpc %}
  enable_vpc     = true
  vpc_id         = "{{ existing_vpc_id | default('') }}"
  {% endif %}

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "keystone-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
