# -----------------------------------------------------------------------------
# MSK (Kafka): {{ cluster_name }} — Auto-generated by Keystone Platform
# Jira: {{ jira_ticket_key }}
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//msk?ref={{ iac_template_ref }}"
}

inputs = {
  cluster_name          = "{{ cluster_name }}"
  kafka_version         = "{{ kafka_version | default('3.6.0') }}"
  broker_instance_type  = "{{ broker_instance_type | default('kafka.m5.large') }}"
  number_of_brokers     = {{ number_of_brokers | default(3) }}
  storage_per_broker_gb = {{ storage_per_broker_gb | default(100) }}

  {% if existing_vpc_id %}
  vpc_id = "{{ existing_vpc_id }}"
  {% endif %}

  # Security
  encryption_in_transit = "TLS"
  encryption_at_rest    = true

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    CostCenter  = "{{ cost_center }}"
    ManagedBy   = "keystone-platform"
    JiraTicket  = "{{ jira_ticket_key }}"
  }
}
