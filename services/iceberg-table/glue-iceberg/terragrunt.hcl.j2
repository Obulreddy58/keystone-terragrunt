# -----------------------------------------------------------------------------
# Iceberg Data Lake: {{ database_name }}.{{ table_name }} — Auto-generated
# Jira: {{ jira_ticket_key }}
# Format: {{ file_format }} ({{ compression }})
# -----------------------------------------------------------------------------

include "root" {
  path = find_in_parent_folders()
}

terraform {
  source = "git::https://github.com/{{ iac_github_org }}/{{ iac_repo_prefix }}.git//glue-iceberg?ref={{ iac_template_ref }}"
}

inputs = {
  database_name = "{{ database_name }}"
  table_name    = "{{ table_name }}"
  file_format   = "{{ file_format }}"
  compression   = "{{ compression }}"

  {% if s3_bucket_name %}
  s3_bucket_name = "{{ s3_bucket_name }}"
  {% endif %}

  {% if partition_columns %}
  partition_columns = {{ partition_columns | tojson }}
  {% endif %}

  tags = {
    Team        = "{{ team_name }}"
    Environment = "{{ environment }}"
    ManagedBy   = "keystone"
    Service     = "iceberg-datalake"
    CostCenter  = "{{ cost_center }}"
    CreatedBy   = "{{ requester_email }}"
  }
}
